/system         erofs     system                                     wait,logical
/vendor         erofs     vendor                                     wait,logical
/product        erofs     product                                    wait,logical
/metadata       ext4      /dev/block/by-name/metadata                wait,check
/data           f2fs      /dev/block/by-name/userdata                wait,check
/boot           emmc      /dev/block/by-name/boot                    wait,slotselect
/vendor_boot    emmc      /dev/block/by-name/vendor_boot             wait,slotselect
/external_sd    vfat      /dev/block/mmcblk0p1  /dev/block/mmcblk0   flags=display="MicroSD";storage;wipeui;removable
/usb_otg        vfat      /dev/block/sdd1       /dev/block/sdd       flags=display="USB-OTG";storage;wipeui;removable
